<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to sensitive files
    RedirectMatch 403 (?i)\.(env|git|htaccess|config)$
    RedirectMatch 403 (?i)/(composer\.json|composer\.lock|package\.json|artisan)$

    # Redirect external requests containing "/public/" to the clean URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^/]+/)*public/([^\s?]*) [NC]
    RewriteRule ^ /%1%2 [R=301,L]

    RewriteCond %{REQUEST_URI} !/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>